<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

    <PropertyGroup>
        <NoDefaultLaunchSettingsFile>true</NoDefaultLaunchSettingsFile>
        <StaticWebAssetProjectMode>Default</StaticWebAssetProjectMode>
        <BlazorWebAssemblyLoadAllGlobalizationData>true</BlazorWebAssemblyLoadAllGlobalizationData>
        <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
        <DefineConstants>TRACE;Gateway</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" />
        <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.Authentication" />
        <PackageReference Include="Microsoft.FluentUI.AspNetCore.Components" />
        <PackageReference Include="Microsoft.FluentUI.AspNetCore.Components.Icons" />
        <PackageReference Include="BlazorTypewriter" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Microscope.Boilerplate.Clients.SDK.GraphQL.Bff\Microscope.Boilerplate.Clients.SDK.GraphQL.Bff.csproj"/>
        <ProjectReference Include="..\Microscope.Boilerplate.Clients.SDK.GraphQL.Gateway\Microscope.Boilerplate.Clients.SDK.GraphQL.Gateway.csproj"/>
        <ProjectReference Include="..\Microscope.Boilerplate.Clients.Web.Shared\Microscope.Boilerplate.Clients.Web.Shared.csproj"/>
    </ItemGroup>

    <ItemGroup>
      <AdditionalFiles Include="Components\Pages\Common\AccessDeniedPage.razor" />
      <AdditionalFiles Include="Components\Pages\Common\NotFoundPage.razor" />
    </ItemGroup>

</Project>
