@using Microscope.Boilerplate.Clients.SDK.GraphQL.Bff
@using Microscope.Boilerplate.Clients.Web.Blazor.Fluent.Components.Shared
@using Microscope.Boilerplate.Clients.Web.Shared.Components
@using StrawberryShake
@inject BffClient BffClient
@inherits LayoutComponentBase

<FluentDesignTheme Mode="@_luminanceMode" NeutralBaseColor="#272727" CustomColor="#02838f" StorageName="theme" />

<FluentLayout>
    <FluentHeader>
        <FluentIcon OnClick="@(() => _isExpanded = !_isExpanded)" Value="@(new Icons.Regular.Size20.Navigation())" Color="Color.Fill" Style="margin-right: 10px; cursor: pointer;" />
        Boilerplate
        
        <FeatureFlag FlagName="ShowAppVersion">
            @_appVersion
        </FeatureFlag>
        
        <FluentSpacer />
        
        <FeatureFlag FlagName="DarkModeAvailable">
            <FluentIcon Id="btnOpenMenuLuminanceMode" OnClick="@(() => _openLuminanceSelector = !_openLuminanceSelector)" Value="@(new Icons.Regular.Size20.DarkTheme())" Style="margin-right: 10px; cursor: pointer;" Color="Color.Fill"/>
            <FluentMenu Anchor="btnOpenMenuLuminanceMode" @bind-Open="_openLuminanceSelector">
                @{
                    var systemColor = _luminanceMode == DesignThemeModes.System ? Color.Accent : Color.Neutral;
                    var lightColor = _luminanceMode == DesignThemeModes.Light ? Color.Accent : Color.Neutral;
                    var darkColor = _luminanceMode == DesignThemeModes.Dark ? Color.Accent : Color.Neutral;
                }
                <FluentMenuItem OnClick="() => SetLuminanceMode(DesignThemeModes.System)">
                    <div style="display:flex; align-items:center; gap:6px;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Lightbulb())" Color="@systemColor" />
                        <FluentLabel Typo="Typography.Body" Color="systemColor">System</FluentLabel>
                    </div>
                </FluentMenuItem>
                <FluentMenuItem OnClick="() => SetLuminanceMode(DesignThemeModes.Light)">
                    <div style="display:flex; align-items:center; gap:6px;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.WeatherSunny())" Color="@lightColor"/>
                        <FluentLabel Typo="Typography.Body" Color="lightColor">Light</FluentLabel>
                    </div>
                </FluentMenuItem>
                <FluentMenuItem OnClick="() => SetLuminanceMode(DesignThemeModes.Dark)">
                    <div style="display:flex; align-items:center; gap:6px;">
                        <FluentIcon Value="@(new Icons.Regular.Size20.DarkTheme())" Color="@darkColor"/>
                        <FluentLabel Typo="Typography.Body" Color="darkColor">Dark</FluentLabel>
                    </div>
                </FluentMenuItem>
            </FluentMenu>
        </FeatureFlag>
        
        <FeatureFlag FlagName="ShowLanguageSelector">
            <LanguageSelector />
        </FeatureFlag>
        
        <LoginDisplay></LoginDisplay>
    </FluentHeader>
    <FluentStack Class="main" Orientation="Orientation.Horizontal" Width="100%">
        <NavMenu IsExpanded="@_isExpanded" />
        <FluentBodyContent Class="body-content">
            <div class="content">
                @Body
            </div>
        </FluentBodyContent>
    </FluentStack>
    <FluentFooter>
        <a href="https://bhtz.github.io/microscope-boilerplate/" target="_blank">Documentation</a>
        <FluentSpacer />
    </FluentFooter>
</FluentLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<FluentToastProvider />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMessageBarProvider />
<FluentMenuProvider />

@code {
    private bool _openLuminanceSelector;
    private bool _isExpanded = true;
    private string _appVersion = string.Empty;
    private DesignThemeModes _luminanceMode = DesignThemeModes.System;

    protected override async Task OnInitializedAsync()
    {
        var result = await BffClient.GetAppVersion.ExecuteAsync();
        if (result.IsSuccessResult())
        {
            _appVersion = result.Data?.AppVersion ?? string.Empty;
        }
    }

    public void SetLuminanceMode(DesignThemeModes mode)
    {
        _luminanceMode = mode;
    } 
}