<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <ContainerRepository>microscope-management/bff</ContainerRepository>
        <ContainerImageTag>latest</ContainerImageTag>
    </PropertyGroup>

    
    <!--#if (Material && Fluent) -->
    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
        <!--        <UI>Fluent</UI>-->
        <UI>Material</UI>
        <DefineConstants Condition="'$(UI)'=='Fluent'">TRACE;Aspire;Yarp;Gateway;Fluent</DefineConstants>
        <DefineConstants Condition="'$(UI)'=='Material'">TRACE;Aspire;Yarp;Gateway;Material</DefineConstants>
    </PropertyGroup>
    <!-- #endif -->
    
    <ItemGroup>
        <PackageReference Include="FluentValidation" />
        <PackageReference Include="HotChocolate.AspNetCore" />
        <PackageReference Include="HotChocolate.AspNetCore.Authorization" />
        <PackageReference Include="HotChocolate.AspNetCore.CommandLine" />
        <PackageReference Include="HotChocolate.Types.Analyzers" />

        <!--#if (Gateway) -->
        <PackageReference Include="HotChocolate.Fusion" />
        <!-- #endif -->

        <PackageReference Include="Microsoft.FeatureManagement.AspNetCore" />
        <PackageReference Include="System.Linq.Async" />

        <!--#if (Yarp) -->
        <PackageReference Include="Yarp.ReverseProxy" />
        <!-- #endif -->

        <PackageReference Include="Microsoft.AspNetCore.Authentication.OpenIdConnect"  />
        <PackageReference Include="Microsoft.Identity.Web" />
        <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.Server" />
    </ItemGroup>
    
    <ItemGroup>
        <ProjectReference Include="..\..\CrossCutting\Microscope.Boilerplate.ServiceDefaults\Microscope.Boilerplate.ServiceDefaults.csproj"/>
    </ItemGroup>

    <ItemGroup Condition="'$(UI)'=='Fluent'">
        <!--#if (Material && Fluent) -->
        <Compile Remove="Components\Pages\MaterialHost.razor"/>
        <Content Remove="Components\Pages\MaterialHost.razor"/>
        <None Remove="Components\Pages\MaterialHost.razor"/>
        <!-- #endif -->
        <ProjectReference Include="..\Microscope.Boilerplate.Clients.Web.Blazor.Fluent\Microscope.Boilerplate.Clients.Web.Blazor.Fluent.csproj"/>
    </ItemGroup>

    <ItemGroup Condition="'$(UI)'=='Material'">
        <!--#if (Material && Fluent) -->
        <Compile Remove="Components\Pages\FluentHost.razor"/>
        <Content Remove="Components\Pages\FluentHost.razor"/>
        <None Remove="Components\Pages\FluentHost.razor"/>
        <!-- #endif -->
        <ProjectReference Include="..\Microscope.Boilerplate.Clients.Web.Blazor.Material\Microscope.Boilerplate.Clients.Web.Blazor.Material.csproj"/>
    </ItemGroup>

    <!--#if (Gateway) -->
    <ItemGroup>
        <None Update="gateway.fgp">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
        <None Update="gateway.Development.fgp">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>
    <!-- #endif -->

</Project>
