{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  
  "AllowedHosts": "*",
  "BaseAddress": "http://localhost:5215/",

  "AccountUrl": "https://localhost:8443/realms/microscope/account",
  "OIDC": {
    "PROVIDER": "OIDC",
    "Authority": "https://localhost:8443/realms/microscope",
    "IssuerAddress": "https://localhost:8443/realms/microscope/protocol/openid-connect/auth",
    "IssuerLogoutAddress": "https://localhost:8443/realms/microscope/protocol/openid-connect/logout",
    "RequireHttpsMetadata": false,
    "ValidateIssuer": false,
    "SaveTokens": true,
    "ClientId": "boilerplate-frontend",
    "ClientSecret": "**********",
    "NameClaimType": "name",
    //    "RoleClaimType": "roles",
    "Scopes": ["roles", "openid", "profile"]
  },

//  "AccountUrl": "https://myaccount.microsoft.com/?ref=MeControl",
//  "OIDC": {
//    "PROVIDER": "AzureAd",
//    "Authority": "https://login.microsoftonline.com/",
//    "CallbackPath": "/signin-oidc",
//    "TenantId" : "<add_tenant_id_here>",
//    "ClientId" : "<add_client_id_here>",
//    "ClientSecret" : "<add_client_secret_here>",
//    "Scopes": ["openid", "profile", "email", "offline_access"]
//  },

  "FeatureManagement": {
    "ShowUserPage": true,
    "DarkModeAvailable": true,
    "ShowAppVersion": true,
    "ShowInteractiveRenderMode": true,
    "ShowLanguageSelector": true
  },
  
  //#if (Gateway)
  "GraphQLGateway": {
    "Scalars": [
      "Single",
      "bigint",
      "timestamp"
    ]
  }
  //#endif

  //#if (Yarp)
  ,"ReverseProxy": {
    "Routes": {
      "post-service": {
        "ClusterId": "post-service",
        "Match": {
          "Path": "/api/todos/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api"
          }
        ]
      }
    },
    "Clusters": {
      "post-service": {
        "Destinations": {
          "post-service": {
            "Address": "https://jsonplaceholder.typicode.com"
          }
        }
      }
    }
  }
  //#endif
}
