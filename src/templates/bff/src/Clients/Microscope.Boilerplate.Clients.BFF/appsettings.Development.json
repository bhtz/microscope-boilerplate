{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "BaseAddress": "http://localhost:5215/",

  "AccountUrl": "http://localhost:8083/realms/microscope/account",
  "OIDC": {
    "PROVIDER": "OIDC",
    "Authority": "http://localhost:8083/realms/microscope/",
    "ClientId": "boilerplate",
    "ClientSecret": "**********",
    "NameClaimType": "name",
    //    "RoleClaimType": "roles",
    "Scopes": ["roles", "openid", "profile"]
  },

  //  "AccountUrl": "https://myaccount.microsoft.com/?ref=MeControl",
  //  "OIDC": {
  //    "PROVIDER": "AzureAd",
  //    "Authority": "https://login.microsoftonline.com/",
  //    "CallbackPath": "/signin-oidc",
  //    "TenantId" : "<add_tenant_id_here>",
  //    "ClientId" : "<add_client_id_here>",
  //    "ClientSecret" : "<add_client_secret_here>",
  //    "Scopes": ["openid", "profile", "email", "offline_access"]
  //  },

  "FeatureManagement": {
    "ShowUserPage": true,
    "DarkModeAvailable": true,
    "ShowAppVersion": true,
    "ShowInteractiveRenderMode": true,
    "ShowLanguageSelector": true
  },

  "GraphQLGateway": {
    "Scalars" : [
      "Single",
      "bigint",
      "timestamp"
    ]
  }

  //#if (Yarp)
  ,"ReverseProxy": {
      "Routes": {
        "post-service" : {
          "ClusterId": "post-service",
          "Match": {
            "Path": "/api/todos/{**catch-all}"
          },
          "Transforms": [
            {
              "PathRemovePrefix": "/api"
            }
          ]
        }
      },
      "Clusters": {
        "post-service": {
          "Destinations": {
            "post-service": {
              "Address": "https://jsonplaceholder.typicode.com"
            }
          }
        }
      }
    }
  //#endif
}
