@using Microscope.Boilerplate.Clients.Web.Shared.Services
@inject IFeatureManagementService FeatureManagementService
@inject PersistentComponentState PersistentComponentState
@implements IDisposable

@if (FeatureIsEnabled == true)
{
    @ChildContent
}
else
{
    @DisabledContent
}

@code {

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? DisabledContent { get; set; }
    [Parameter] public required string FlagName { get; set; }

    private bool? FeatureIsEnabled { get; set; }
    private PersistingComponentStateSubscription? PersistingSubscription { get; set; }

    protected override async Task OnInitializedAsync()
    {
        PersistingSubscription = PersistentComponentState.RegisterOnPersisting(PersistFeatureState);

        if (string.IsNullOrEmpty(FlagName))
        {
            return;
        }

        if (PersistentComponentState.TryTakeFromJson<bool?>(FlagName, out var persistedState))
        {
            FeatureIsEnabled = persistedState;
            return;
        }

        var features = await FeatureManagementService.GetFeatureManagement();
        FeatureIsEnabled = features != null && features.FirstOrDefault(x => x.Key == FlagName).Value;
    }

    private Task PersistFeatureState()
    {
        if (!string.IsNullOrEmpty(FlagName) && FeatureIsEnabled != null)
        {
            PersistentComponentState.PersistAsJson(FlagName, FeatureIsEnabled);
        }

        return Task.CompletedTask;
    }

    public void Dispose()
    {
        PersistingSubscription?.Dispose();
    }
}