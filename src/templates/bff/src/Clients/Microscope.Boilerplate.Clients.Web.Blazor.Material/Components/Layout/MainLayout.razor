@using Microscope.Boilerplate.Clients.SDK.GraphQL.Bff
@using Microscope.Boilerplate.Clients.Web.Blazor.Material.Components.Shared
@using Microscope.Boilerplate.Clients.Web.Shared.Components
@using Microscope.Boilerplate.Clients.Web.Shared.Services
@using Microscope.Management.Clients.Web.Blazor.Material.Settings
@using StrawberryShake
@inject BffClient BffClient
@inject ISnackbar Snackbar
@inject MaterialThemeService ThemeService
@inherits LayoutComponentBase
@implements IDisposable

<MudThemeProvider @ref="_mudThemeProvider" ObserveSystemDarkModeChange="true" @bind-IsDarkMode="@ThemeService.IsDarkMode" Theme="@ThemeService.AppTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <AuthorizeView>
            <MudIconButton Icon="@Icons.Material.Outlined.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="((e) => ToggleDrawer())"/>
        </AuthorizeView>

        <MudText Class="cursor-pointer" @onclick="GoToHome">Boilerplate</MudText>
        <FeatureFlag FlagName="ShowAppVersion">
            <MudText Class="ml-2">@_appVersion</MudText>
        </FeatureFlag>
        
        <FeatureFlag FlagName="ShowInteractiveRenderMode">
            @if (RendererInfo.Name == "Server")
            {
                <MudProgressCircular Class="ml-2" Size="Size.Small" Color="Color.Inherit" Indeterminate="true"></MudProgressCircular>
            }
        </FeatureFlag>
        <MudSpacer/>
        <FeatureFlag FlagName="DarkModeAvailable">
            <ThemeSelector />
            
            @{
                var icon = ThemeService.IsDarkMode ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode;
                var systemColor = ThemeService.LuminanceMode == LuminanceMode.System ? Color.Primary : Color.Inherit;
                var lightColor = ThemeService.LuminanceMode == LuminanceMode.Light ? Color.Primary : Color.Inherit;
                var darkColor = ThemeService.LuminanceMode == LuminanceMode.Dark ? Color.Primary : Color.Inherit;
            }
            <MudMenu Icon="@icon" Color="Color.Inherit">
                <MudMenuItem OnClick="() => SetLuminanceMode(LuminanceMode.System)" Label="System" Icon="@Icons.Material.Filled.Lightbulb" IconColor="@systemColor" />
                <MudMenuItem OnClick="() => SetLuminanceMode(LuminanceMode.Light)" Label="Light" Icon="@Icons.Material.Filled.LightMode" IconColor="@lightColor" />
                <MudMenuItem OnClick="() => SetLuminanceMode(LuminanceMode.Dark)" Label="Dark" Icon="@Icons.Material.Filled.DarkMode" IconColor="@darkColor" />
            </MudMenu>
        </FeatureFlag>
        <FeatureFlag FlagName="ShowLanguageSelector">
            <LanguageSelector/>
        </FeatureFlag>
        <LoginDisplay/>
    </MudAppBar>
    
    <AuthorizeView>
        <MudDrawer @bind-open="DrawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="DrawerVariant.Mini" MiniWidth="60px">
            <NavMenu/>
        </MudDrawer>
    </AuthorizeView>
    
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private string _appVersion = string.Empty;
    private MudThemeProvider? _mudThemeProvider;
    private bool DrawerOpen { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitializeAsync(); // pre-rendering
        ThemeService.OnChange += StateHasChanged;
        
        var result = await BffClient.GetAppVersion.ExecuteAsync();
        if (result.IsSuccessResult())
        {
            _appVersion = result.Data?.AppVersion ?? string.Empty;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeAsync();
            if (ThemeService.LuminanceMode == LuminanceMode.System)
            {
                var systemDarkMode = await _mudThemeProvider?.GetSystemDarkModeAsync()!;
                ThemeService.SetDarkMode(systemDarkMode);
            }
            
            StateHasChanged();
        }
    }

    public void ToggleDrawer()
    {
        DrawerOpen = !DrawerOpen;
    }

    private async Task SetLuminanceMode(LuminanceMode mode)
    {
        await ThemeService.SetLuminance(mode);
        
        if (ThemeService.LuminanceMode == LuminanceMode.System)
        {
            var systemDarkMode = await _mudThemeProvider?.GetSystemDarkModeAsync()!;
            ThemeService.SetDarkMode(systemDarkMode);
        }
        else
        {
            ThemeService.ApplyLuminance();
        }

        StateHasChanged();
    }
    
    private void GoToHome()
    {
        NavigationManager.NavigateTo("/");
    }

    public void Dispose()
    {
        ThemeService.OnChange -= StateHasChanged;
    }
}
