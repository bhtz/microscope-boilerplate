@using Microscope.Boilerplate.Clients.Web.Blazor.Material.Settings
@using Microscope.Management.Clients.Web.Blazor.Material.Settings
@inject MaterialThemeService ThemeService

<MudMenu Icon="@Icons.Material.Filled.ColorLens" Color="Color.Inherit" AnchorOrigin="Origin.BottomCenter" Dense="true">
    <MudMenuItem OnClick="@(() => ThemeService.SetTheme(nameof(Theme.MicroscopeTheme)))">Microscope</MudMenuItem>
    <MudMenuItem OnClick="@(() => ThemeService.SetTheme(nameof(Theme.SkylineTheme)))">Skyline</MudMenuItem>
    <MudMenuItem OnClick="@(() => ThemeService.SetTheme(nameof(Theme.MudTheme)))">Mud</MudMenuItem>
</MudMenu>
