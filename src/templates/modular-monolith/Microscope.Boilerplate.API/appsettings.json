{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "OIDC": {
    "Authority": "https://localhost:8443/realms/microscope/",
    "ClientId": "boilerplate-api",
    "McpResource" : "https://localhost:7245/mcp"
  },

  "ApiKey": {
    "Realm": "microscope",
    "KeyName": "X-MICROSCOPE-MASTER-KEY",
    "MasterKey": "https://localhost:8443/realms/microscope_devmasterkey"
  },
  
  // EF CORE configuration
  //  "TodoPersistence": {
  //    "Framework" : "efcore",
  //    "ConnectionString": "User ID =postgres;Password=root;Server=host.docker.internal;Port=5432;Database=mcsp_app;",
  //    "Schema" : "efcore",
  //    "Adapter": "postgres",
  //    "EnableMigration": "true"
  //  },

  // MARTEN configuration
  "TodoPersistence": {
    "Framework" : "marten",
    "ConnectionString": "User ID =postgres;Password=root;Server=host.docker.internal;Port=5432;Database=mcsp_app;",
    "Schema": "marten"
  },

  "FeatureManagement": {
    "GetTodoVersionQuery" : true
  },

  "McpEndpoint": "https://localhost:7245/mcp",
  "AI": {
    "Provider": "openai",
    "EndPoint" : "https://api.openai.com/v1",
    "Model": "gpt-4o-mini" // "gpt-5-nano"
  },

  "Users": {
    "Adapter": "keycloak",
    "UserServiceEndpoint": "https://localhost:8443/admin/realms/microscope/users"
  },

  "Mail": {
    "Adapter": "smtp"
  },

  "Storage": {
    "Adapter": "filesystem",
    "DefaultStorageContainer": "todoapp"
  },

  "Bus": {
    "Adapter": "rabbitmq",
    "Host": "amqp://guest:guest@localhost:5672",
    "Username" : "guest",
    "Password" : "guest"
  }
}


