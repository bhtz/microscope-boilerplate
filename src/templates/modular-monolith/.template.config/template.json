{
  "$schema": "http://json.schemastore.org/template",
  "author": "Benjamin HEINTZ",
  
  "classifications": [
    "Modular",
    "Monolith",
    "MartenDB",
    "EfCore",
    "Vertical slice",
    "GraphQL",
    "REST",
    "gRPC",
    "MCP",
    "Aspire"
  ],
  
  "identity": "Microscope.Boilerplate.Service",
  "name": "Microscope boilerplate Service",
  "shortName": "mcsp_service",
  "sourceName": "Microscope.Boilerplate",

  "symbols": {
    "GraphQL": {
      "type": "parameter",
      "description": "Add GraphQL protocol",
      "datatype": "bool",
      "defaultValue": false
    },
    
    "Rest": {
      "type": "parameter",
      "description": "Add REST protocol",
      "datatype": "bool",
      "defaultValue": false
    },

    "Grpc": {
      "type": "parameter",
      "description": "Add gRPC protocol",
      "datatype": "bool",
      "defaultValue": false
    },

    "Mcp": {
      "type": "parameter",
      "description": "Add Mcp protocol",
      "datatype": "bool",
      "defaultValue": false
    },

    "Aspire": {
      "type": "parameter",
      "description": "Add Aspire support",
      "datatype": "bool",
      "defaultValue": false
    },

    "UnitTest": {
      "type": "parameter",
      "description": "Add Unit test",
      "datatype": "bool",
      "defaultValue": false
    }
  },
  
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/[Bb]in/**",
            "**/[Oo]bj/**",
            ".template.config/**/*",
            "**/*.filelist",
            "**/*.user",
            "**/*.lock.json",
            ".idea/**/*"
          ]
        },
        
        {
          "condition": "(!GraphQL)",
          "exclude": [
            "**/*Resolver.cs",
            "**/*GraphQL*/**",
            "**/GraphQL/**",
            "**/GraphQLExtensions.cs"
          ]
        },
        
        {
          "condition": "(!Rest)",
          "exclude": [
            "**/*Controller.cs",
            "**/*Endpoints.cs",
            "**/OpenApiExtensions.cs",
            "**/RestExtensions.cs",
            "**/*RestExtensions.cs",
            "**/*RestConfiguration.cs"
          ]
        },

        {
          "condition": "(!Grpc)",
          "exclude": [
            "**/Protos/**",
            "**/GrpcExtensions.cs",
            "**/*RpcService.cs",
            "**/*GrpcService.cs"
          ]
        },

        {
          "condition": "(!Mcp)",
          "exclude": [
            "**/*McpTool.cs",
            "**/McpExtensions.cs",
            "Modules/Ai/**"
          ]
        },
        
        {
          "condition": "(!Aspire)",
          "exclude": [
            "IAC/Aspire/**",
            "Microscope.Boilerplate.ServiceDefaults/**"
          ]
        },

        {
          "condition": "(!Docker && !Aspire)",
          "exclude": [
            "src/IAC/Docker/**"
          ]
        },

        {
          "condition": "(!UnitTest)",
          "exclude": [
            "Modules/Todo/Microscope.Boilerplate.Todo.Domain.Tests.Unit/**"
          ]
        }
      ]
    }
  ]
}