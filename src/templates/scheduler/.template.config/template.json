{
  "$schema": "http://json.schemastore.org/template",
  "author": "Benjamin HEINTZ",
  
  "classifications": [
    "Scheduler",
    "TickerQ",
    "Postgres"
  ],
  
  "identity": "Microscope.Boilerplate.Scheduler",
  "name": "Microscope boilerplate Scheduler",
  "shortName": "mcsp_scheduler",
  "sourceName": "Microscope.Boilerplate",

  "symbols": {
    "Aspire": {
      "type": "parameter",
      "description": "Add Aspire support (provide authentication using keycloak)",
      "datatype": "bool",
      "defaultValue": false
    }
  },
  
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/[Bb]in/**",
            "**/[Oo]bj/**",
            ".template.config/**/*",
            "**/*.filelist",
            "**/*.user",
            "**/*.lock.json",
            ".idea/**/*"
          ]
        },
        
        {
          "condition": "(!Aspire)",
          "exclude": [
            "IAC/Aspire/**",
            "**/Extensions/AuthenticationExtensions.cs",
            "**/Extensions/CookieOidcRefresher.cs",
            "**/Extensions/CookieOidcRefresherExtensions.cs",
            "**/Endpoints/**",
            "Microscope.Boilerplate.ServiceDefaults/**"
          ]
        }
      ]
    }
  ]
}